    <https://w3id.org/okn/i/mint/1a0e8797-5ef0-4e96-ad05-0dc129c60f4c>
            a       <https://w3id.org/okn/o/sdm#Model> ;
            <http://www.w3.org/2000/01/rdf-schema#label>
                    "DroughtPredict" ;
            <https://w3id.org/okn/o/sd#author>
                    <https://w3id.org/okn/i/mint/khider_deborah> ;
            <https://w3id.org/okn/o/sd#description>
                    "DoughtPredict uses deep learning to make predictions of SPI on a variety of timescales. \n\nSee the specific version and configuration for information on the deep learning model structure and training/testing data." ;
            <https://w3id.org/okn/o/sd#hasPurpose>
                    "Drought predictions up to four months into the future." ;
            <https://w3id.org/okn/o/sd#hasSampleVisualization>
                    <https://w3id.org/okn/i/mint/ad4b4e24-eb07-4431-a68f-67e1e27c0a01> , <https://w3id.org/okn/i/mint/6b5d2046-ed7f-4d8d-bec7-a1183bd7517c> ;
            <https://w3id.org/okn/o/sd#hasUsageNotes>
                    "Quality determined from Pearson’s correlation coefficient on test dataset varies between a spatial average of 0.8 at 1 month lead down to 0.4 at 4-month lead. Tends to underestimate magnitude of extreme events. Visualizations can be found here: https://github.com/mintproject/DroughtPredictViz (Use Binder)." ;
            <https://w3id.org/okn/o/sd#hasVersion>
                    <https://w3id.org/okn/i/mint/20b92d72-8e5f-48f6-9730-2ff98ef6a4e2> ;
            <https://w3id.org/okn/o/sd#keywords>
                    "Drought prediction, standardized precipitation index, deep learning" ;
            <https://w3id.org/okn/o/sd#license>
                    "https://www.apache.org/licenses/LICENSE-2.0"^^<http://www.w3.org/2001/XMLSchema#anyURI> ;
            <https://w3id.org/okn/o/sd#logo>
                    <https://w3id.org/okn/i/mint/7bda4351-282e-4e30-9ba9-c81b7d828819> ;
            <https://w3id.org/okn/o/sd#shortDescription>
                    "DoughtPredict uses deep learning to make predictions of SPI on a variety of timescales." ;
            <https://w3id.org/okn/o/sd#usefulForCalculatingIndex>
                    <https://w3id.org/okn/i/mint/standardized_precipitation_index> ;
            <https://w3id.org/okn/o/sdm#hasModelCategory>
                    <https://w3id.org/okn/i/mint/Weather> .
    
